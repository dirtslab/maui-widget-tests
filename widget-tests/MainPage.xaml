<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="widget_tests.MainPage"
             Title="Pie Chart Widget">

    <ScrollView>
        <VerticalStackLayout
            Padding="30,20"
            Spacing="16">

            <Label
                Text="Pie Chart Widget"
                Style="{StaticResource Headline}"
                SemanticProperties.HeadingLevel="Level1" />

            <Label
                Text="Enter values for each slice. Changes will update the home screen widget."
                Style="{StaticResource SubHeadline}" />

            <!-- Slice 1 -->
            <Label Text="Slice 1" FontAttributes="Bold" />
            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                <Entry x:Name="Label1" Grid.Column="0" Placeholder="Label (e.g. Alpha)" Text="Alpha" Keyboard="Text" />
                <Entry x:Name="Value1" Grid.Column="1" Placeholder="Value" Text="40" Keyboard="Numeric" />
            </Grid>

            <!-- Slice 2 -->
            <Label Text="Slice 2" FontAttributes="Bold" />
            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                <Entry x:Name="Label2" Grid.Column="0" Placeholder="Label (e.g. Beta)" Text="Beta" Keyboard="Text" />
                <Entry x:Name="Value2" Grid.Column="1" Placeholder="Value" Text="30" Keyboard="Numeric" />
            </Grid>

            <!-- Slice 3 -->
            <Label Text="Slice 3" FontAttributes="Bold" />
            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                <Entry x:Name="Label3" Grid.Column="0" Placeholder="Label (e.g. Gamma)" Text="Gamma" Keyboard="Text" />
                <Entry x:Name="Value3" Grid.Column="1" Placeholder="Value" Text="20" Keyboard="Numeric" />
            </Grid>

            <!-- Slice 4 -->
            <Label Text="Slice 4" FontAttributes="Bold" />
            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                <Entry x:Name="Label4" Grid.Column="0" Placeholder="Label (e.g. Delta)" Text="Delta" Keyboard="Text" />
                <Entry x:Name="Value4" Grid.Column="1" Placeholder="Value" Text="10" Keyboard="Numeric" />
            </Grid>

            <Label x:Name="StatusLabel"
                   Text=""
                   TextColor="Green"
                   HorizontalOptions="Center" />

            <Button
                Text="Update Pie Chart Widget"
                SemanticProperties.Hint="Sends the values to the pie chart widget"
                Clicked="OnUpdateWidgetClicked"
                HorizontalOptions="Fill" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
